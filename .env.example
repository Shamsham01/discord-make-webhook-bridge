# Required: Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=

# Persistent JSON configuration file.
# On Render with a persistent disk mounted at /data, use /data/guilds.json.
DATA_FILE=./data/guilds.json

# Webhook request timeout. Make AI scenarios can take longer than normal webhooks.
WEBHOOK_TIMEOUT_MS=120000

# Security allow-list. Comma-separated exact hosts or wildcard suffixes.
# *.make.com permits standard Make webhook zones such as hook.eu1.make.com.
# Use * only when you fully trust server administrators; it increases SSRF risk.
ALLOWED_WEBHOOK_HOSTS=*.make.com

# Optional message reactions. Leave blank to disable.
ACK_REACTION=👀
SUCCESS_REACTION=
ERROR_REACTION=⚠️

# Send a generic Discord reply when the webhook fails.
SHOW_DELIVERY_ERRORS=true

# Health-check web server port (required by many hosting platforms).
PORT=3000
